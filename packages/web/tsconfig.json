{
  "compilerOptions": {
    "target": "es6",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "noImplicitReturns": false,
    "strictNullChecks": false
  },
  "include": ["src"],
  "baseUrl": "./",
  "paths": {
    "@src/*": ["@selene/app/src/*"],
    "@components/*": ["@selene/app/src/components/*"],
    "@atoms/*": ["@selene/app/src/components/atoms/*"],
    "@design/*": ["@selene/app/src/design/*"],
    "@redux/*": ["@selene/app/src/redux/*"],
    "@types/*": ["@selene/app/src/types/*"],
    "@utils/*": ["@selene/app/src/utils/*"]
  }
}
